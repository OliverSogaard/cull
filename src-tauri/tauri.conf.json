{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CULL",
  "version": "0.1.0",
  "identifier": "dev.cull.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CULL",
        "width": 1600,
        "height": 1000,
        "minWidth": 800,
        "minHeight": 500,
        "backgroundColor": "#000000",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg"],
    "publisher": "Olive",
    "copyright": "© 2026 Olive",
    "category": "Photography",
    "shortDescription": "Keyboard-fast culling for Canon CR3 RAW photos.",
    "longDescription": "CULL is a desktop app for picking keepers from a folder of Canon CR3 RAW photos. Verdicts save into Lightroom-compatible XMP sidecars so picks and rejects round-trip into Lightroom Classic. Single image (loupe), side-by-side (compare), and contact-sheet (grid) views share one keyboard vocabulary.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
